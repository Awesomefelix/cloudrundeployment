# Server
PORT=8080
NODE_ENV=development

# Database (Cloud SQL via Unix socket in production, TCP in dev)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Cloud SQL (production only — used when NODE_ENV=production)
# Format: /cloudsql/PROJECT_ID:REGION:INSTANCE_NAME
CLOUD_SQL_INSTANCE_CONNECTION_NAME=your-project:us-central1:your-instance

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Password Reset
RESET_TOKEN_EXPIRES_MINUTES=30

# Optional: SendGrid (for real email on forgot password)
# SENDGRID_API_KEY=your_sendgrid_api_key
# FROM_EMAIL=noreply@yourdomain.com
